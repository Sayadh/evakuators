# PostgreSQL connection string
DATABASE_URL="postgresql://evakuators:CHANGE_ME@localhost:5432/evakuators?schema=public"

# Supabase — used ONLY for Storage (never Database, never Auth)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME"
SUPABASE_STORAGE_BUCKET="tow-truck-images"

# HTTP — 4002 is reserved for the Evakuators backend (3002 is the frontend, do not swap)
PORT=4002
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3002,https://evakuators.am"

# Driver self-service login (Telegram OTP) — see README "Driver login" section
# Bot token from @BotFather (message it, /newbot)
TELEGRAM_BOT_TOKEN="CHANGE_ME"
# Bot username WITHOUT the @, e.g. EvakuatorsBot
TELEGRAM_BOT_USERNAME="CHANGE_ME"
# Random string you invent — Telegram echoes it back on every webhook call so we
# can verify the request really came from Telegram. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET="CHANGE_ME"
# Signs driver dashboard JWTs — must be long and random. Generate with: openssl rand -hex 32
DRIVER_JWT_SECRET="CHANGE_ME"
