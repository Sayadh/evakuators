# PostgreSQL connection string
DATABASE_URL="postgresql://evakuators:CHANGE_ME@localhost:5432/evakuators?schema=public"

# Supabase — used ONLY for Storage (never Database, never Auth)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME"
SUPABASE_STORAGE_BUCKET="tow-truck-images"

# HTTP — 4002 is reserved for the Evakuators backend (3002 is the frontend, do not swap)
PORT=4002
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3002,https://evakuators.am"
