# PostgreSQL connection string
DATABASE_URL="postgresql://evakuators:CHANGE_ME@localhost:5432/evakuators?schema=public"

# Supabase — used ONLY for Storage (never Database, never Auth)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="CHANGE_ME"
SUPABASE_STORAGE_BUCKET="tow-truck-images"

# HTTP — 4002 is reserved for the Evakuators backend (3002 is the frontend, do not swap)
PORT=4002
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3002,https://evakuators.am"

# Public site URL — used to build the "Login" button link sent in Telegram
# messages (driver-link-confirmation, OTP code). No trailing slash.
FRONTEND_URL="https://evakuators.am"

# Driver self-service login (Telegram OTP) — see README "Driver login" section
# Bot token from @BotFather (message it, /newbot)
TELEGRAM_BOT_TOKEN="CHANGE_ME"
# Bot username WITHOUT the @, e.g. EvakuatorsBot
TELEGRAM_BOT_USERNAME="CHANGE_ME"
# Random string you invent — Telegram echoes it back on every webhook call so we
# can verify the request really came from Telegram. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET="CHANGE_ME"
# Signs driver dashboard JWTs — must be long and random. Generate with: openssl rand -hex 32
DRIVER_JWT_SECRET="CHANGE_ME"

# Admin panel login — see README "Admin panel" section.
# Signs admin JWTs (separate secret from DRIVER_JWT_SECRET on purpose — compromising
# one must not compromise the other). Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET="CHANGE_ME"

# Admin 2-factor login + new-registration notifications, via a SEPARATE
# dedicated Telegram bot (do NOT reuse TELEGRAM_BOT_TOKEN above — see
# docs/auth-and-security.md for why). Fully optional: leave blank and admin
# login stays single-factor (email+password only). Once set, create the bot
# with @BotFather, register its webhook (see docs/deployment.md), then run
# `npm run admin:telegram-link -- <admin-email>` and tap the link it prints —
# 2FA turns on automatically for that account the moment it's linked.
ADMIN_TELEGRAM_BOT_TOKEN=""
# Bot username WITHOUT the @
ADMIN_TELEGRAM_BOT_USERNAME=""
# Random string you invent — generate with: openssl rand -hex 32
ADMIN_TELEGRAM_WEBHOOK_SECRET=""
# Comma-separated Telegram numeric chat ids allowed to use this bot at all
# (link, /start, everything else is silently ignored for anyone else — no
# reply, not even to a valid link token). Get your own chat id by messaging
# @userinfobot on Telegram. Leave blank = unrestricted (any valid link token
# still works, same as before this was added).
ADMIN_TELEGRAM_ALLOWED_CHAT_IDS=""
