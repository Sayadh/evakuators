// Evakuators.am — dynamic business data only.
// Static geography (regions, cities, districts) and static dictionaries
// (service types, vehicle types) live in the FRONTEND as TypeScript constants
// and are referenced here by their slugs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
}

enum FreeRouteStatus {
  /// Shown on the public listing, still open for a customer to grab
  ACTIVE
  /// Past its departure time — kept briefly for the driver's own history,
  /// then hard-deleted by the cleanup cron (see free-routes.service.ts)
  FINISHED
}

model TowTruck {
  id             Int     @id @default(autoincrement())
  slug           String  @unique
  driverName     String
  companyName    String?
  phone          String
  secondaryPhone String?
  whatsapp       String?
  telegram       String?
  email          String?
  works24Hours   Boolean @default(false)
  description    String

  // Vehicle
  vehicleBrand    String
  vehicleModel    String?
  vehicleYear     Int
  /// VehicleType slug from frontend constants (flatbed, sliding-platform, ...)
  vehicleType     String
  capacityTons    Float
  platformLengthM Float?
  platformWidthM  Float?
  winch           Boolean @default(true)
  manipulator     Boolean @default(false)
  plateNumber     String?
  showPlateNumber Boolean @default(false)

  // Base location — slugs reference frontend static data
  regionSlug   String?
  citySlug     String?
  districtSlug String?
  locationName String

  /// ServiceType slugs from frontend constants
  services     String[]
  /// [{ name, slug, type: "city" | "district" | "region" }]
  serviceAreas Json

  // Pricing — fully optional; missing values are simply not displayed
  priceCityCallout           Int?
  pricePerKm                 Int?
  priceWaitingPerHour        Int?
  priceNightSurchargePercent Int?
  priceExtraLoading          Int?

  isActive  Boolean  @default(true)
  /// Admin-curated "best tow trucks" homepage pick — see FeaturedTowTrucksSection
  /// on the frontend. Purely editorial, has no effect on public search/filter
  /// results elsewhere.
  isFeatured Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     TowTruckImage[]
  reviews    Review[]
  freeRoutes FreeRoute[]

  // Driver self-service login (Telegram OTP) — see DriverOtp
  /// Telegram numeric chat id, captured once the driver taps the bot deep-link.
  /// Null until linked; the driver cannot log in before that.
  telegramChatId BigInt? @unique
  /// One-time token embedded in the t.me/<bot>?start=<token> link. Cleared once used.
  telegramLinkToken          String?   @unique
  telegramLinkTokenExpiresAt DateTime?
  otps                       DriverOtp[]

  @@index([citySlug])
  @@index([districtSlug])
  @@index([regionSlug])
  @@index([isActive])
  @@index([isFeatured])
}

/// Short-lived login codes sent to the driver's linked Telegram chat.
model DriverOtp {
  id         Int       @id @default(autoincrement())
  towTruckId Int
  towTruck   TowTruck  @relation(fields: [towTruckId], references: [id], onDelete: Cascade)
  /// SHA-256 hash of the 6-digit code — the raw code is never stored
  codeHash   String
  expiresAt  DateTime
  /// Failed verify attempts against this code — locked out after 5
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([towTruckId])
}

model TowTruckImage {
  id        Int      @id @default(autoincrement())
  /// Storage object path inside the Supabase bucket
  path      String   @unique
  /// Public URL served by Supabase Storage
  url       String
  width     Int
  height    Int
  sizeBytes Int
  position  Int      @default(0)
  createdAt DateTime @default(now())

  towTruckId Int?
  towTruck   TowTruck? @relation(fields: [towTruckId], references: [id], onDelete: Cascade)

  registrationRequestId Int?
  registrationRequest   RegistrationRequest? @relation(fields: [registrationRequestId], references: [id], onDelete: SetNull)

  @@index([towTruckId])
  @@index([registrationRequestId])
}

model Review {
  id         Int      @id @default(autoincrement())
  towTruckId Int
  towTruck   TowTruck @relation(fields: [towTruckId], references: [id], onDelete: Cascade)
  authorName String
  rating     Int
  text       String
  cityName   String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([towTruckId])
}

model RegistrationRequest {
  id     Int                @id @default(autoincrement())
  status RegistrationStatus @default(PENDING)

  firstName      String
  lastName       String
  companyName    String?
  phone          String
  secondaryPhone String?
  whatsapp       String?
  telegram       String?
  email          String?

  vehicleBrand       String
  vehicleModel       String?
  vehicleYear        Int
  vehicleType        String
  /// CAPACITY_RANGE_OPTIONS value from frontend constants (e.g. "2-3.5") — required
  capacityRange      String
  /// Free-form, validated on the frontend (e.g. "5.5 մ × 2.2 մ")
  platformDimensions String?
  winch              Boolean @default(false)
  manipulator        Boolean @default(false)
  // No works24Hours column here — it's just one of the `services` slugs the
  // driver picks (see backend/src/tow-trucks/service-slugs.ts). TowTruck
  // below keeps a real boolean column, but only as a derived sort/filter index.

  mainRegionSlug String
  citySlugs      String[]
  services       String[]

  priceCityCallout           Int?
  pricePerKm                 Int?
  priceWaitingPerHour        Int?
  priceNightSurchargePercent Int?
  priceExtraLoading          Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images TowTruckImage[]

  @@index([status])
}

/// "Ազատ երթուղիներ" — a driver heading somewhere empty posts a route so
/// customers going the same way can find them. Geography here is just slugs
/// (frontend static data), same convention as TowTruck/RegistrationRequest.
model FreeRoute {
  id         Int      @id @default(autoincrement())
  towTruckId Int
  towTruck   TowTruck @relation(fields: [towTruckId], references: [id], onDelete: Cascade)

  startRegionSlug String
  startCitySlug   String
  endRegionSlug   String
  endCitySlug     String

  /// Departure date + time combined. This IS the auto-expiry deadline —
  /// once it passes the cleanup cron flips ACTIVE -> FINISHED, then hard
  /// deletes FINISHED rows after a short grace period (see FreeRoutesService).
  departureAt DateTime

  /// Optional free-text note from the driver, shown on the public card
  /// (e.g. "կարող եմ սպասել կես ժամ")
  description String?

  status    FreeRouteStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([towTruckId])
  @@index([status, departureAt])
}

/// Admin accounts — created only via `npm run admin:create`, no self-registration.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Telegram-based 2FA for admin login (separate dedicated bot from the
  // driver one — see AdminTelegramService) + new-registration notifications.
  // Same linking mechanism as TowTruck.telegramChatId: null until the admin
  // taps a one-time link generated by `npm run admin:telegram-link`. Login
  // stays single-factor (password only) until this is set.
  telegramChatId             BigInt?    @unique
  telegramLinkToken          String?    @unique
  telegramLinkTokenExpiresAt DateTime?
  otps                       AdminOtp[]
}

/// Short-lived 2FA login codes sent to an admin's linked Telegram chat.
/// Mirrors DriverOtp exactly, just keyed to User instead of TowTruck.
model AdminOtp {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// SHA-256 hash of the 6-digit code — the raw code is never stored
  codeHash   String
  expiresAt  DateTime
  /// Failed verify attempts against this code — locked out after 5
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}
